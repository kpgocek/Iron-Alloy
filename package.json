{
  "name": "theme-validation",
  "version": "1.0.0",
  "private": true,
  "description": "CI validation tools for theme repository",
  "license": "MIT",
  "devDependencies": {
    "semver": "^7.6.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  },
  "scripts": {
    "lint:css": "stylelint theme.css",
    "lint:css:fix": "stylelint --fix theme.css",

    "validate:manifest:syntax": "node -e \"JSON.parse(require('fs').readFileSync('manifest.json','utf8'))\"",
    "validate:manifest": "node validators/validate-manifest.js"
  }
}